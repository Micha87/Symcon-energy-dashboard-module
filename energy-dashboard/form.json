{
  "elements": [
    {
      "type": "ValidationTextBox",
      "name": "Title",
      "caption": "Titel"
    },
    {
      "type": "SelectVariable",
      "name": "PvPowerID",
      "caption": "PV-Leistung (W)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "400px"
    },
    {
      "type": "SelectVariable",
      "name": "GridPowerID",
      "caption": "Netzleistung (W, Bezug + / Einspeisung -)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "400px"
    },
    {
      "type": "SelectVariable",
      "name": "LoadPowerID",
      "caption": "Hausverbrauch (W)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "400px"
    },
    {
      "type": "SelectVariable",
      "name": "BatteryPowerID",
      "caption": "Batterie-Leistung (W, Laden - / Entladen +, optional)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "400px"
    },
    {
      "type": "PopupButton",
      "caption": "Optionale kWh-Zähler",
      "popup": {
        "items": [
          {
            "type": "Label",
            "caption": "Wenn gesetzt, überschreiben diese Tageszähler die aus Leistung berechneten Übersichtswerte."
          },
          {
            "type": "SelectVariable",
            "name": "PvEnergyTodayID",
            "caption": "PV heute (kWh)",
            "validVariableTypes": [
              1,
              2
            ],
            "width": "400px"
          },
          {
            "type": "SelectVariable",
            "name": "GridImportTodayID",
            "caption": "Netzbezug heute (kWh)",
            "validVariableTypes": [
              1,
              2
            ],
            "width": "400px"
          },
          {
            "type": "SelectVariable",
            "name": "GridExportTodayID",
            "caption": "Einspeisung heute (kWh)",
            "validVariableTypes": [
              1,
              2
            ],
            "width": "400px"
          },
          {
            "type": "SelectVariable",
            "name": "LoadEnergyTodayID",
            "caption": "Verbrauch heute (kWh)",
            "validVariableTypes": [
              1,
              2
            ],
            "width": "400px"
          },
          {
            "type": "SelectVariable",
            "name": "BatteryChargeTodayID",
            "caption": "Batterie Laden heute (kWh)",
            "validVariableTypes": [
              1,
              2
            ],
            "width": "400px"
          },
          {
            "type": "SelectVariable",
            "name": "BatteryDischargeTodayID",
            "caption": "Batterie Entladen heute (kWh)",
            "validVariableTypes": [
              1,
              2
            ],
            "width": "400px"
          }
        ]
      }
    },
    {
      "type": "NumberSpinner",
      "name": "ArchiveControlID",
      "caption": "Archivsteuerung-ID (0 = automatisch suchen)"
    },
    {
      "type": "Select",
      "name": "SourceAggregation",
      "caption": "Aggregation Stromquellen",
      "options": [
        {
          "caption": "5 Minuten",
          "value": 5
        },
        {
          "caption": "1 Minute",
          "value": 6
        },
        {
          "caption": "Stündlich",
          "value": 0
        }
      ]
    },
    {
      "type": "Select",
      "name": "UsageAggregation",
      "caption": "Aggregation Stromnutzung",
      "options": [
        {
          "caption": "Stündlich",
          "value": 0
        },
        {
          "caption": "5 Minuten",
          "value": 5
        },
        {
          "caption": "1 Minute",
          "value": 6
        }
      ]
    },
    {
      "type": "NumberSpinner",
      "name": "RefreshSeconds",
      "caption": "Aktualisierung alle x Sekunden"
    },
    {
      "type": "NumberSpinner",
      "name": "BucketMinutes",
      "caption": "Fallback-Balkenraster in Minuten"
    },
    {
      "type": "NumberSpinner",
      "name": "MaxSourcePoints",
      "caption": "Max. Punkte Stromquellen-Chart"
    },
    {
      "type": "NumberSpinner",
      "name": "MaxUsagePoints",
      "caption": "Max. Punkte Stromnutzung-Chart"
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Jetzt aktualisieren",
      "onClick": "EDB_UpdateVisualization($id);"
    },
    {
      "type": "Label",
      "caption": "Optimiert auf AC_GetAggregatedValues und SelectVariable."
    }
  ],
  "status": [
    {
      "code": 101,
      "icon": "inactive",
      "caption": "Wird erstellt"
    },
    {
      "code": 102,
      "icon": "active",
      "caption": "Aktiv"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Fehler"
    }
  ]
}
