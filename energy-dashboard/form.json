{
  "elements": [
    {
      "type": "ValidationTextBox",
      "name": "Title",
      "caption": "Titel"
    },
    {
      "type": "SelectVariable",
      "name": "PvPowerID",
      "caption": "PV-Leistung (W)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "420px"
    },
    {
      "type": "CheckBox",
      "name": "InvertPv",
      "caption": "PV-Vorzeichen invertieren"
    },
    {
      "type": "SelectVariable",
      "name": "GridPowerID",
      "caption": "Netzleistung (W, Bezug + / Einspeisung -)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "420px"
    },
    {
      "type": "CheckBox",
      "name": "InvertGrid",
      "caption": "Netz-Vorzeichen invertieren"
    },
    {
      "type": "SelectVariable",
      "name": "LoadPowerID",
      "caption": "Hausverbrauch (W)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "420px"
    },
    {
      "type": "CheckBox",
      "name": "InvertLoad",
      "caption": "Verbrauch-Vorzeichen invertieren"
    },
    {
      "type": "SelectVariable",
      "name": "BatteryPowerID",
      "caption": "Batterie-Leistung (W, optional)",
      "validVariableTypes": [
        1,
        2
      ],
      "width": "420px"
    },
    {
      "type": "CheckBox",
      "name": "InvertBattery",
      "caption": "Batterie-Vorzeichen invertieren"
    },
    {
      "type": "ExpansionPanel",
      "caption": "Historische Tages-kWh",
      "items": [
        {
          "type": "CheckBox",
          "name": "UseHistoricalDayEnergy",
          "caption": "Historische Tages-kWh für Übersicht verwenden"
        },
        {
          "type": "Label",
          "caption": "Wenn für den gewählten Tag geloggte Tageswerte vorhanden sind, werden diese bevorzugt verwendet."
        },
        {
          "type": "SelectVariable",
          "name": "PvEnergyDayID",
          "caption": "PV Tages-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "GridImportEnergyDayID",
          "caption": "Netzbezug Tages-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "GridExportEnergyDayID",
          "caption": "Einspeisung Tages-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "LoadEnergyDayID",
          "caption": "Verbrauch Tages-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "BatteryChargeEnergyDayID",
          "caption": "Batterie Laden Tages-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "BatteryDischargeEnergyDayID",
          "caption": "Batterie Entladen Tages-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        }
      ]
    },
    {
      "type": "ExpansionPanel",
      "caption": "Historische kWh-Gesamtzähler",
      "items": [
        {
          "type": "CheckBox",
          "name": "UseHistoricalCounterDiff",
          "caption": "Bei fehlenden Tages-kWh Zählerdifferenz verwenden"
        },
        {
          "type": "Label",
          "caption": "Tageswert = Zählerstand Tagesende minus Zählerstand Tagesanfang."
        },
        {
          "type": "SelectVariable",
          "name": "PvEnergyTotalID",
          "caption": "PV Gesamt-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "GridImportEnergyTotalID",
          "caption": "Netzbezug Gesamt-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "GridExportEnergyTotalID",
          "caption": "Einspeisung Gesamt-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "LoadEnergyTotalID",
          "caption": "Verbrauch Gesamt-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "BatteryChargeEnergyTotalID",
          "caption": "Batterie Laden Gesamt-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        },
        {
          "type": "SelectVariable",
          "name": "BatteryDischargeEnergyTotalID",
          "caption": "Batterie Entladen Gesamt-kWh",
          "validVariableTypes": [
            1,
            2
          ],
          "width": "420px"
        }
      ]
    },
    {
      "type": "NumberSpinner",
      "name": "ArchiveControlID",
      "caption": "Archivsteuerung-ID (0 = automatisch suchen)"
    },
    {
      "type": "Select",
      "name": "SourceAggregation",
      "caption": "Aggregation Stromquellen",
      "options": [
        {
          "caption": "Stündlich",
          "value": 0
        },
        {
          "caption": "5 Minuten",
          "value": 5
        },
        {
          "caption": "1 Minute",
          "value": 6
        }
      ]
    },
    {
      "type": "Select",
      "name": "UsageAggregation",
      "caption": "Aggregation Stromnutzung",
      "options": [
        {
          "caption": "Stündlich",
          "value": 0
        },
        {
          "caption": "5 Minuten",
          "value": 5
        },
        {
          "caption": "1 Minute",
          "value": 6
        }
      ]
    },
    {
      "type": "NumberSpinner",
      "name": "RefreshSeconds",
      "caption": "Aktualisierung alle x Sekunden"
    },
    {
      "type": "NumberSpinner",
      "name": "MaxSourcePoints",
      "caption": "Max. Punkte Stromquellen-Chart"
    },
    {
      "type": "NumberSpinner",
      "name": "MaxUsagePoints",
      "caption": "Max. Punkte Stromnutzung-Chart"
    }
  ],
  "actions": [
    {
      "type": "Button",
      "caption": "Jetzt aktualisieren",
      "onClick": "EDB_UpdateVisualization($id);"
    },
    {
      "type": "Button",
      "caption": "Heute anzeigen",
      "onClick": "EDB_GoToToday($id);"
    },
    {
      "type": "Button",
      "caption": "Vortag",
      "onClick": "EDB_PreviousDay($id);"
    },
    {
      "type": "Button",
      "caption": "Nächster Tag",
      "onClick": "EDB_NextDay($id);"
    },
    {
      "type": "Label",
      "caption": "IDs werden komplett über das Formular gewählt. Historische Tages-kWh werden bevorzugt, danach optional Zählerdifferenz, danach Leistungsintegration."
    }
  ],
  "status": [
    {
      "code": 101,
      "icon": "inactive",
      "caption": "Wird erstellt"
    },
    {
      "code": 102,
      "icon": "active",
      "caption": "Aktiv"
    },
    {
      "code": 201,
      "icon": "error",
      "caption": "Fehler"
    }
  ]
}
